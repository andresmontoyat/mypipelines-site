---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { STACK_ORDER, STACK_LABELS } from '../lib/stacks';
import { defaultLocale, t } from '../i18n/ui';

const lang = defaultLocale;
const all = await getCollection('pipelines');
const counts = Object.fromEntries(
  STACK_ORDER.map((s) => [s, all.filter((e) => e.data.stack === s).length])
);
const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.order - b.data.order || a.data.slug.localeCompare(b.data.slug)
);
---

<BaseLayout title={t(lang, 'site.title')} lang={lang}>
  <main class="mx-auto max-w-5xl px-4 py-16">
    <section class="text-center">
      <h1 class="text-fluid-h1 font-semibold tracking-[-0.02em] text-[var(--fg)]">Los pipelines que usamos, para que no los armes de cero</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-[var(--fg-muted)]">
        GitHub Actions por stack, con GitFlow, gates de seguridad y deploy ya resueltos.
        En vez de pelearte con el YAML, copiás el de tu stack, cambiás <code>&lt;org&gt;</code> y arrancás.
      </p>
    </section>

    <section class="mt-12">
      <div class="rounded-lg border border-[var(--border-subtle)] surface p-4 font-mono text-sm">
        <p class="text-[var(--fg-muted)]"># .github/workflows/main-deploy.yml</p>
        <p>uses: &lt;org&gt;/ci-templates/.github/workflows/java-main-pipeline.yml@v1</p>
      </div>
    </section>

    <section class="mt-12 grid grid-cols-2 md:grid-cols-3 gap-4">
      {STACK_ORDER.map((s) => (
        <a href={`/stacks/${s}`}
           class="rounded-lg border border-[var(--border-subtle)] surface p-6 hover:border-brand-500 transition-colors">
          <h2 class="font-semibold text-[var(--fg)]">{STACK_LABELS[s]}</h2>
          <p class="mt-1 text-sm text-[var(--fg-muted)]">{counts[s]} pipelines</p>
        </a>
      ))}
    </section>

    <section class="mt-16">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--fg-subtle)]">Guías</h2>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-4">
        {guides.map((g) => (
          <a href={`/guides/${g.data.slug}`}
             class="rounded-lg border border-[var(--border-subtle)] surface p-5 hover:border-brand-500 transition-colors">
            <h3 class="font-semibold text-[var(--fg)]">{g.data.title}</h3>
            <p class="mt-1 text-sm text-[var(--fg-muted)] line-clamp-2">{g.data.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--fg-subtle)]">Más por acá</h2>
      <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { href: '/actions', title: 'Actions', desc: 'Nuestras GitHub Actions' },
          { href: '/gradle', title: 'Gradle', desc: 'Cómo lo usamos, con ejemplos' },
          { href: '/reference/rulesets', title: 'Referencia', desc: 'Rulesets y CODEOWNERS' },
        ].map((c) => (
          <a href={c.href}
             class="rounded-lg border border-[var(--border-subtle)] surface p-5 hover:border-brand-500 transition-colors">
            <h3 class="font-semibold text-[var(--fg)]">{c.title}</h3>
            <p class="mt-1 text-sm text-[var(--fg-muted)]">{c.desc}</p>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
