---
import BaseLayout from '../layouts/BaseLayout.astro';
import { defaultLocale, t } from '../i18n/ui';
const lang = defaultLocale;
---
<BaseLayout title={t(lang, 'nav.search')} lang={lang}>
  <main class="mx-auto max-w-3xl px-4 py-10">
    <h1 class="text-fluid-h1 font-semibold tracking-[-0.02em] text-[var(--fg)] mb-6">{t(lang, 'nav.search')}</h1>
    <div id="pagefind-search" class="pagefind-ui"></div>
  </main>
</BaseLayout>

<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<!-- pagefind-ui.js is a global-assigning bundle (window.PagefindUI), NOT an ES module —
     load via <script src> and read the global; is:inline keeps Astro/Vite from processing it. -->
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI === 'undefined') {
      const el = document.getElementById('pagefind-search');
      if (el) el.innerHTML = '<p class="text-[var(--fg-muted)] text-sm">El índice de búsqueda aún no está disponible. Ejecutá <code>pnpm build</code>.</p>';
      return;
    }
    new PagefindUI({
      element: '#pagefind-search',
      showImages: false,
      resetStyles: false,
    });
  });
</script>
