---
import { t, type Locale } from '../i18n/ui';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<button
  id="theme-toggle"
  type="button"
  aria-label={t(lang, 'theme.toggleLabel')}
  class="relative rounded p-2 text-[var(--fg-muted)] transition-colors duration-[var(--duration-fast)] hover:bg-[var(--surface-raised)] hover:text-brand-500"
>
  <span class="relative block h-5 w-5">
    <!-- Sun icon — visible in dark mode (click to switch to light) -->
    <svg
      class="absolute inset-0 h-5 w-5 rotate-90 opacity-0 transition-[opacity,transform] duration-[var(--duration-base)] ease-[var(--ease-out)] dark:rotate-0 dark:opacity-100"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <circle cx="12" cy="12" r="5" /><path
        d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"
      />
    </svg>
    <!-- Moon icon — visible in light mode (click to switch to dark) -->
    <svg
      class="absolute inset-0 h-5 w-5 rotate-0 opacity-100 transition-[opacity,transform] duration-[var(--duration-base)] ease-[var(--ease-out)] dark:-rotate-90 dark:opacity-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
    >
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
    </svg>
  </span>
</button>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
